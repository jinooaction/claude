# auto-invest — required runtime secrets.
#
# Copy this file to `.env` (gitignored) and fill in the real values.
# The worker refuses to start if any of these are missing or empty
# (FR-011, constitution V).
#
# Every value loaded here is registered with the redaction filter, so
# it will appear as ***REDACTED*** in every log line, error message,
# and report (FR-009).

# KIS Developers application key. Issued at https://apiportal.koreainvestment.com/
KIS_APP_KEY=

# KIS Developers application secret (paired with KIS_APP_KEY).
KIS_APP_SECRET=

# KIS account number with overseas-stock trading enabled.
# Format is the broker's CANO/ACNT_PRDT pair without the dash, or as
# documented by KIS at the time of account provisioning.
KIS_ACCOUNT_NO=

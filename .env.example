# auto-invest — required runtime secrets and operator config.
#
# Copy this file to `.env` (gitignored) and fill in the real values.
# The worker refuses to start if any KIS_* key is missing or empty
# (FR-011, constitution V). The redaction filter masks every value
# loaded from here as ***REDACTED*** in every log line, error
# message, and report (FR-009).

# ---------------- KIS broker secrets (REQUIRED) ----------------

# KIS Developers application key. Issued at
# https://apiportal.koreainvestment.com/.
KIS_APP_KEY=

# KIS Developers application secret (paired with KIS_APP_KEY).
KIS_APP_SECRET=

# KIS account number with overseas-stock trading enabled.
# Format is the broker's CANO/ACNT_PRDT pair without the dash, or as
# documented by KIS at the time of account provisioning.
KIS_ACCOUNT_NO=

# ---------------- Claude API (spec 010 자동 룰 설계자에 필수) ----------------

# Anthropic Console에서 발급 (https://console.anthropic.com/settings/keys).
# `auto-invest design --intent "..."` 명령이 룰 자동 설계를 할 때 사용.
# `auto-invest run` (실거래 워커)만 쓰려면 비워둬도 됨. 비어 있으면 design
# 명령만 동작 안 함.
ANTHROPIC_API_KEY=

# ---------------- Worker runtime knobs (REQUIRED for systemd) ----

# Per-session USD capital the worker treats as the global denominator
# for the position caps (constitution I). Used by deploy/auto-invest.service
# as the --capital flag. Pick a number you are comfortable risking
# the FULL of, since per-symbol cap × this number is the exposure
# ceiling per name.
AUTO_INVEST_CAPITAL=10000

# 워커 모드 토글. 'dry-run' (기본, 실주문 안 나감) / 'live' (실주문).
# 처음 가동 시 dry-run으로 두고 1주일 관찰 후 'live'로 바꾸세요.
# 변경 후: systemctl restart auto-invest.service
AUTO_INVEST_MODE=dry-run

# ---------------- Optional knobs ---------------------------------

# Path to the operator-declared rule set the worker loads at startup.
# The default points at tests/fixtures/rules/sample-canary.toml which
# trades AAPL/MSFT/SPY conservatively — replace with your own
# config/rules.toml when you are ready.
# AUTO_INVEST_RULES=config/rules.toml

# SQLite database location. Defaults to data/auto_invest.db relative
# to the working directory.
# AUTO_INVEST_DB=data/auto_invest.db
